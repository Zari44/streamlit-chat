
[

    // -----------------------------------
    // ------ keybindings.json file ------
    // -----------------------------------

    // Place your key bindings in this file to override the defaults

    // Make up and down cycle thourgh search results in `Shift+Ctrl+F` instead of search history
    // ref: https://github.com/microsoft/vscode/issues/78655
    { "key": "down", "command": "-history.showNext" },
    { "key": "up", "command": "-history.showPrevious" },
    { "key": "up", "command": "search.focus.previousInputBox", "when": "inputBoxFocus && searchViewletVisible" },
    { "key": "down", "command": "search.focus.nextInputBox", "when": "inputBoxFocus && searchViewletVisible" },
    { "key": "up", "command": "search.focus.previousInputBox", "when": "firstMatchFocus && searchViewletVisible" },
    { "key": "ctrl+up", "command": "search.focus.previousInputBox", "when": "searchViewletVisible" },


    // open and close terminal
    {
        "key": "cmd+t",
        "command": "terminal.focus"
    },
    {
        "key": "cmd+t",
        "command": "-git.sync",
        "when": "!operationInProgress"
    },
    {
        "key": "cmd+t",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminal.active && terminalFocus"
    },


    // fold and unfold
    //  note: usually when I fold I want to fold all, but when I unfold I want to unfold recursively
    //  so I added for now only the unfold and kept fold commented
    {
        "key": "cmd+shift+=",
        "command": "editor.unfoldRecursively"
    },
    // {
    //     "key": "cmd+shift+-",
    //     "command": "editor.foldRecursively"
    // },


    // create files and folder in explorer using keyboard similar to jetbrains IDE
    {
        "key": "cmd+n",
        "command": "explorer.newFile",
        "when": "explorerViewletFocus"
    },
    {
        "key": "cmd+shift+n",
        "command": "explorer.newFolder",
        "when": "explorerViewletFocus"
    },

    // search files by name while in explorer view
    // the default alt+cmd+f will still work
    // this will override finding in the editor while in the explorer focus
    {
        "key": "cmd+f",
        "command": "list.find",
        "when": "listFocus && listSupportsFind"
    },


    // from anywhere, focus on editor without closing the panes
    // if I remove the when, then also when cmd+b in a method, I can't return
    // so I mannually set a few common use cases
    {
        "key": "escape",
        "command": "workbench.action.focusFirstEditorGroup",
        "when": "explorerViewletFocus || terminalFocus || agentsPaneFocused"
    },

    // I don't like that zenmode is closed when I by mistake click esc twice
    {
        "key": "escape escape",
        "command": "-workbench.action.exitZenMode",
        "when": "inZenMode"
    },

    {
        "key": "alt+shift+left",
        "command": "workbench.action.navigateBack",
        "when": "canNavigateBack"
    },

    {
        "key": "alt+shift+right",
        "command": "workbench.action.navigateForward",
        "when": "canNavigateForward"
    }

]
