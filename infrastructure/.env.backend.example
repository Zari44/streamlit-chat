# Backend Environment Variables
# Copy this file to .env.backend and fill in your actual values

# Domain Configuration
DOMAIN_URL=goatbot.com.pl

# Backend Service Configuration
STREAMLIT_URL=http://streamlit-chat:8501

# Auth0 Configuration (if using authentication)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_BASE_URL=goatbot.com.pl
AUTH0_CALLBACK_URL=https://goatbot.com.pl/api/auth/callback
AUTH0_AUDIENCE=
