# Copy this file to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars

aws_region = "eu-north-1"
project_name = "goatbot"
instance_type = "t3.small"

# REQUIRED: Replace with your AWS key pair name
key_pair_name = "goatbot_ec2_key_pair"

# Volume size in GB (minimum 30GB for Amazon Linux 2023)
volume_size = 2

# SSH access - restrict to your IP for security
# Example: ["1.2.3.4/32"] for a specific IP
ssh_allowed_cidrs = ["0.0.0.0/0"]

# Allocate Elastic IP for static IP address
allocate_elastic_ip = true

# Domain name (optional, for Caddy configuration)
domain_name = ""
